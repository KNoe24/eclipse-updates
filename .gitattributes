# Force Git to treat JAR files as raw binary data (Prevents line-ending corruption)
*.jar filter=lfs diff=lfs merge=lfs -text
# Ensure JSON and other text configuration files use consistent Linux line endings
*.json text eol=lf
*.txt text eol=lf
*.properties text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
# Global fallback: treat all other files as text with auto-normalization to LF
* text=auto eol=lf
